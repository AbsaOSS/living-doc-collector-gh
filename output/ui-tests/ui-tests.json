            "scenario_name": "User can complete the Create Domain wizard and create a new domain",
            "scenario_type": "Scenario",
            "tags": [
                "Regression"
            ],
            "steps": [
                {
                    "keyword": "Given",
                    "text": "the user \"1\" is logged in"
                },
                {
                    "keyword": "And",
                    "text": "the user is on the Create Domain wizard About screen"
                },
                {
                    "keyword": "When",
                    "text": "the user fills in the domain name \"<unique>\""
                },
                {
                    "keyword": "And",
                    "text": "the user fills in the description \"domain for automated testing\""
                },
                {
                    "keyword": "And",
                    "text": "the user fills in the cost center \"AB123456\""
                },
                {
                    "keyword": "And",
                    "text": "the user fills in the cost center owner \"ab024ll\""
                },
                {
                    "keyword": "And",
                    "text": "the user clicks Continue"
                },
                {
                    "keyword": "Then",
                    "text": "the user is on the Create Domain wizard Owner screen"
                },
                {
                    "keyword": "When",
                    "text": "the user clicks Continue"
                },
                {
                    "keyword": "Then",
                    "text": "the user is on the Create Domain wizard Classification screen"
                },
                {
                    "keyword": "When",
                    "text": "the user clicks Continue"
                },
                {
                    "keyword": "Then",
                    "text": "the user is on the Create Domain wizard Scheduling screen"
                },
                {
                    "keyword": "When",
                    "text": "the user clicks Continue"
                },
                {
                    "keyword": "Then",
                    "text": "the user is on the Create Domain wizard Availability screen"
                },
                {
                    "keyword": "When",
                    "text": "the user clicks Continue"
                },
                {
                    "keyword": "Then",
                    "text": "the user is on the Create Domain wizard Target dataset screen"
                },
                {
                    "keyword": "When",
                    "text": "the user add attribute with name \"name\", description \"description\", nullable \"true\", and type \"string\""
                },
                {
                    "keyword": "And",
                    "text": "the user clicks Finish domain setup"
                },
                {
                    "keyword": "Then",
                    "text": "the user is on the Edit Domain Summary screen"
                },
                {
                    "keyword": "And",
                    "text": "the user should see success message \"The domain was successfully updated\" on the Edit Domain Summary screen"
                }
            ],
            "source": {
