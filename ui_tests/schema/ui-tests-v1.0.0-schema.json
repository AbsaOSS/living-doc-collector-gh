{
  "$defs": {
    "Step": {
      "description": "A single Gherkin step within a scenario.",
      "properties": {
        "keyword": {
          "title": "Keyword",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "keyword",
        "text"
      ],
      "title": "Step",
      "type": "object"
    },
    "ScenarioSource": {
      "description": "Source identity of a scenario.",
      "properties": {
        "org": {
          "title": "Org",
          "type": "string"
        },
        "repo": {
          "title": "Repo",
          "type": "string"
        },
        "file": {
          "title": "File",
          "type": "string"
        }
      },
      "required": [
        "org",
        "repo",
        "file"
      ],
      "title": "ScenarioSource",
      "type": "object"
    },
    "UITestItem": {
      "description": "Represents a single UI test scenario from the collector output.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "us_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Us Id"
        },
        "ac_ids": {
          "items": {
            "type": "string"
          },
          "title": "Ac Ids",
          "type": "array"
        },
        "scenario_name": {
          "title": "Scenario Name",
          "type": "string"
        },
        "scenario_type": {
          "title": "Scenario Type",
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/Step"
          },
          "title": "Steps",
          "type": "array"
        },
        "source": {
          "$ref": "#/$defs/ScenarioSource"
        }
      },
      "required": [
        "id",
        "us_id",
        "ac_ids",
        "scenario_name",
        "scenario_type",
        "tags",
        "steps",
        "source"
      ],
      "title": "UITestItem",
      "type": "object"
    },
    "AdapterMetadataProducer": {
      "description": "Producer information for adapter metadata.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        },
        "build": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Build"
        }
      },
      "required": [
        "name",
        "version",
        "build"
      ],
      "title": "AdapterMetadataProducer",
      "type": "object"
    },
    "AdapterMetadataRun": {
      "description": "Run information for adapter metadata.",
      "properties": {
        "run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Run Id"
        },
        "run_attempt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Run Attempt"
        },
        "actor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Actor"
        },
        "workflow": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Workflow"
        },
        "ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Ref"
        },
        "sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Sha"
        }
      },
      "required": [
        "run_id",
        "run_attempt",
        "actor",
        "workflow",
        "ref",
        "sha"
      ],
      "title": "AdapterMetadataRun",
      "type": "object"
    },
    "AdapterMetadataSource": {
      "description": "Source information for adapter metadata.",
      "properties": {
        "systems": {
          "items": {
            "type": "string"
          },
          "title": "Systems",
          "type": "array"
        },
        "repositories": {
          "items": {
            "type": "string"
          },
          "title": "Repositories",
          "type": "array"
        },
        "organization": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Organization"
        },
        "enterprise": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Enterprise"
        }
      },
      "required": [
        "systems",
        "repositories",
        "organization",
        "enterprise"
      ],
      "title": "AdapterMetadataSource",
      "type": "object"
    },
    "AdapterMetadata": {
      "description": "Metadata information from the adapter.",
      "properties": {
        "producer": {
          "$ref": "#/$defs/AdapterMetadataProducer"
        },
        "run": {
          "$ref": "#/$defs/AdapterMetadataRun"
        },
        "source": {
          "$ref": "#/$defs/AdapterMetadataSource"
        },
        "original_metadata": {
          "additionalProperties": true,
          "title": "Original Metadata",
          "type": "object"
        }
      },
      "required": [
        "producer",
        "run",
        "source",
        "original_metadata"
      ],
      "title": "AdapterMetadata",
      "type": "object"
    },
    "CompatibilityWarning": {
      "description": "Represents a compatibility warning during adapter processing.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "context": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Context"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "CompatibilityWarning",
      "type": "object"
    }
  },
  "description": "Complete UI test catalog result from the ui-tests collector.",
  "properties": {
    "items": {
      "items": {
        "$ref": "#/$defs/UITestItem"
      },
      "title": "Items",
      "type": "array"
    },
    "metadata": {
      "$ref": "#/$defs/AdapterMetadata"
    },
    "warnings": {
      "items": {
        "$ref": "#/$defs/CompatibilityWarning"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "items",
    "metadata",
    "warnings"
  ],
  "title": "UITestsResult",
  "type": "object",
  "$schema_version": "1.0.0"
}
